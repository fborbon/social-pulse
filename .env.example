POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse
POSTGRES_DB=social_pulse

KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ── Reddit (https://www.reddit.com/prefs/apps) ────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=social-pulse/1.0

# ── Mastodon (any instance, e.g. mastodon.social) ─────────────────────────────
MASTODON_BASE_URL=https://mastodon.social
MASTODON_ACCESS_TOKEN=

# ── Bluesky (bsky.app → Settings → App Passwords) ────────────────────────────
BLUESKY_HANDLE=yourhandle.bsky.social
BLUESKY_APP_PASSWORD=

# ── The Guardian (https://open-platform.theguardian.com/access/) ──────────────
GUARDIAN_API_KEY=

# ── NewsAPI (https://newsapi.org/register) ────────────────────────────────────
NEWSAPI_KEY=

# ── New York Times (https://developer.nytimes.com/) ───────────────────────────
NYTIMES_API_KEY=

# ── AWS Bedrock (uses EC2 IAM role — no key needed when deployed on EC2) ──────
# Only set these if running locally without an IAM role:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1

# ── RSS feeds (comma-separated URLs) ─────────────────────────────────────────
# Default covers: world news, tech, science, business, health, culture
RSS_FEEDS=https://feeds.bbci.co.uk/news/rss.xml,https://feeds.reuters.com/reuters/topNews,https://feeds.npr.org/1001/rss.xml,https://www.theverge.com/rss/index.xml,https://feeds.arstechnica.com/arstechnica/index,https://techcrunch.com/feed/,https://www.nature.com/nature.rss,https://www.bls.gov/feed/bls_latest.rss,https://feeds.feedburner.com/ign/all

REDIS_URL=redis://redis:6379
