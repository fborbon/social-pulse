POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse
POSTGRES_DB=social_pulse

KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Reddit (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=social-pulse/1.0

# Mastodon (any instance, e.g. mastodon.social)
MASTODON_BASE_URL=https://mastodon.social
MASTODON_ACCESS_TOKEN=

# AI provider (leave blank to use stub)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Topics to track (comma-separated)
TRACK_TOPICS=artificial intelligence,climate change,cryptocurrency,elections

# RSS feeds to monitor (comma-separated URLs)
RSS_FEEDS=https://feeds.bbci.co.uk/news/rss.xml,https://rss.cnn.com/rss/edition.rss

REDIS_URL=redis://redis:6379
